# ==========================================
# StreamCPA - Environment Variables
# Copy to .env.local and fill in your values
# ==========================================

# ---- Database ----
# Local Docker:
DATABASE_URL="postgresql://streamcpa:streamcpa_dev@localhost:5432/streamcpa?schema=public"
# Supabase:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?schema=public"
# Direct connection (for migrations):
DATABASE_URL_DIRECT="postgresql://streamcpa:streamcpa_dev@localhost:5432/streamcpa"

# ---- NextAuth.js ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="" # Generate with: openssl rand -base64 32

# ---- Twitch OAuth ----
# Create app at https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# ---- Google OAuth (optional) ----
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ---- Stripe (Payments) ----
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..." # From stripe listen --forward-to localhost:3000/api/stripe/webhook
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ---- Redis ----
# Local Docker:
REDIS_URL="redis://localhost:6379"
# Upstash (production):
# UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""

# ---- Resend (Transactional Email) ----
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY="re_..."
EMAIL_FROM="StreamCPA <noreply@streamcpa.com>"

# ---- PayPal (Payouts) ----
# Dashboard: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox" # sandbox | live

# ---- Wise (Payouts - optional) ----
# WISE_API_KEY=""
# WISE_PROFILE_ID=""

# ---- Supabase Storage (File Uploads) ----
# NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

# ---- App Config ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="StreamCPA"
NEXT_PUBLIC_TRACKING_DOMAIN="http://localhost:3000" # Custom domain for /r/ links
PLATFORM_FEE_PERCENT="20" # StreamCPA takes 20% of CPA payouts
MIN_WITHDRAWAL_AMOUNT="50" # Minimum $50 to withdraw

# ---- Inngest (Background Jobs) ----
# INNGEST_EVENT_KEY=""
# INNGEST_SIGNING_KEY=""

# ---- Fraud Detection ----
FRAUD_SCORE_THRESHOLD="70" # Flag clicks with score >= 70
FRAUD_AUTO_REJECT_THRESHOLD="95" # Auto-reject conversions with score >= 95

# ---- Docker (only for docker-compose) ----
POSTGRES_PASSWORD="streamcpa_dev"
